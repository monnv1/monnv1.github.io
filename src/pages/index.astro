---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { projects } from '../data/projects';
import { slugify, sortPostsByDate } from '../lib/blog';

const posts = sortPostsByDate(await getCollection('blog')).slice(0, 3);
---

<BaseLayout title="个人主页" description="技术博客、项目记录和个人思考。">
  <section class="hero">
    <p class="eyebrow">Personal Homepage</p>
    <h1>你好，我是 Your Name。</h1>
    <p class="hero-copy">
      我在这里记录技术学习、项目实践和一些长期思考。这个网站用 Astro 和 Markdown/MDX 搭建，保持简单、快速、可维护。
    </p>
    <div class="actions">
      <a class="button primary" href="/blog/">阅读博客</a>
      <a class="button" href="/about/">了解我</a>
    </div>
  </section>

  <section class="section">
    <div class="section-heading">
      <h2>最近文章</h2>
      <a href="/blog/">全部文章</a>
    </div>
    <div class="post-list">
      {
        posts.map((post) => (
          <article class="post-card">
            <div class="post-meta">
              <a class="category-link" href={`/categories/${slugify(post.data.category)}/`}>
                {post.data.category}
              </a>
              <time datetime={post.data.pubDate.toISOString()}>
                {post.data.pubDate.toLocaleDateString('zh-CN')}
              </time>
            </div>
            <h3><a href={`/blog/${post.slug}/`}>{post.data.title}</a></h3>
            <p>{post.data.description}</p>
            <div class="tags">
              {post.data.tags.map((tag) => (
                <a href={`/tags/${slugify(tag)}/`}>{tag}</a>
              ))}
            </div>
          </article>
        ))
      }
    </div>
  </section>

  <section class="section">
    <div class="section-heading">
      <h2>精选项目</h2>
      <a href="/projects/">全部项目</a>
    </div>
    <div class="project-grid">
      {
        projects.slice(0, 2).map((project) => (
          <article class="project-card">
            <h3>{project.href ? <a href={project.href}>{project.title}</a> : project.title}</h3>
            <p>{project.description}</p>
            <div class="tags">
              {project.tags.map((tag) => <span>{tag}</span>)}
            </div>
          </article>
        ))
      }
    </div>
  </section>
</BaseLayout>
